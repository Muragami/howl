
class Vector2
    _x = 0
    _y = 0

    construct new(nx, ny)
        _x = nx
        _y = ny
    ;

    +(other)
        _x = _x + other.x
        _y = _y + other.y
    ;

    length(other) Math.sqrt(Math.pow(other.x - _x, 2) + Math.pow(other.y - _y, 2))
;

class Point is Vector2
    construct new(nx, ny)
        super.new(nx, ny)
    ;
;

class Distance is Vector2
    construct new(nx, ny)
        super.new(nx, ny)
    ;
;